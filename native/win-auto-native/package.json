{
  "name": "win-auto-native",
  "version": "0.1.8",
  "description": "Native addon skeleton for win-auto (Rust + napi-rs).",
  "repository": {
    "type": "git",
    "url": "https://github.com/mihailDamchevski/win-auto.git",
    "directory": "native/win-auto-native"
  },
  "bugs": {
    "url": "https://github.com/mihailDamchevski/win-auto/issues"
  },
  "homepage": "https://github.com/mihailDamchevski/win-auto/tree/main/native/win-auto-native#readme",
  "license": "AGPL-3.0",
  "author": "Your Name",
  "main": "index.js",
  "files": [
    "index.js",
    "*.node",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:arm64": "napi build --platform --target aarch64-pc-windows-msvc --release",
    "build:x64": "napi build --platform --target x86_64-pc-windows-msvc --release",
    "clean": "rimraf *.node",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "napi": {
    "name": "win-auto-native",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  }
}
