{
  "name": "win-auto-monorepo",
  "version": "0.1.2",
  "description": "Windows desktop automation framework skeleton with TS API, CLI, and napi-rs native addon.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mihailDamchevski/win-auto.git"
  },
  "bugs": {
    "url": "https://github.com/mihailDamchevski/win-auto/issues"
  },
  "homepage": "https://github.com/mihailDamchevski/win-auto#readme",
  "license": "MIT",
  "author": "Mihail Damchevski",
  "workspaces": [
    "packages/*",
    "native/win-auto-native"
  ],
  "scripts": {
    "build": "npm run build -w @win-auto/core && npm run build -w win-auto && npm run build:native",
    "publish:all": "node scripts/publish-all.js",
    "bump:patch": "node scripts/bump-versions.js",
    "build:native": "npm run build -w win-auto-native",
    "test": "npm run test -w @win-auto/core && npm run test:e2e",
    "test:e2e": "vitest run tests/e2e/native-ping.test.ts",
    "test:e2e:real": "vitest run tests/e2e/notepad-real.test.ts",
    "debug:notepad": "node scripts/debug-notepad-discovery.js",
    "example:notepad": "node -e \"require('./packages/core/dist').Automation && console.log('Build complete. Run examples/notepad.ts with your TS runner.')\"",
    "lint": "eslint packages/",
    "typecheck": "tsc -b --pretty false",
    "format": "prettier --write \"packages/**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,json,md}\"",
    "coverage": "vitest run --coverage",
    "clean": "rimraf packages/*/dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.3",
    "@win-auto/core": "0.1.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.4",
    "@vitest/coverage-v8": "^3.1.1",
    "vitest": "^3.1.1"
  }
}
